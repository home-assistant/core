{
  "common": {
    "password_description": "The password of your my-PV device. When no custom password is set you have to use the **devicekey** which can be found under the ⓘ info menu of your my-PV device. For the HEA•THOR IoT you can find the **devicekey** on the device label.",
    "token": "my-PV Cloud API Access Token",
    "token_description": "To generate a my-PV Cloud API Access Token go to your [my-PV Cloud]({cloud_url}) and navigate to ⚙️ > **Device Setup**. Enable **Advanced Settings**, navigate to **API** and **Generate API Access Token**. Use this when setting up the my-PV integration."
  },
  "config": {
    "abort": {
      "already_configured": "[%key:common::config_flow::abort::already_configured_device%]",
      "reauth_successful": "[%key:common::config_flow::abort::reauth_successful%]"
    },
    "error": {
      "cannot_connect": "[%key:common::config_flow::error::cannot_connect%]",
      "invalid_cloud_api_token": "Invalid my-PV Cloud API Access Token",
      "invalid_password": "Invalid password",
      "invalid_serial_number": "Invalid serial number",
      "invalid_serial_number_or_cloud_api_token": "Invalid serial number or my-PV Cloud API Access Token",
      "unknown": "[%key:common::config_flow::error::unknown%]"
    },
    "step": {
      "discovery_confirm": {
        "data": {
          "password": "[%key:common::config_flow::data::password%]"
        },
        "data_description": {
          "password": "[%key:component::my_pv::common::password_description%]"
        },
        "description": "Do you want to set up {name}?",
        "title": "{name}"
      },
      "local_auth": {
        "data": {
          "password": "[%key:common::config_flow::data::password%]"
        },
        "data_description": {
          "password": "[%key:component::my_pv::common::password_description%]"
        },
        "title": "{name} password"
      },
      "reauth_cloud": {
        "data": {
          "token": "[%key:component::my_pv::common::token%]"
        },
        "data_description": {
          "token": "[%key:component::my_pv::common::token_description%]"
        },
        "description": "The my-PV integration needs to re-authenticate with your my-PV Cloud.",
        "title": "Authentication expired for {name}"
      },
      "reauth_local": {
        "data": {
          "password": "[%key:common::config_flow::data::password%]"
        },
        "data_description": {
          "password": "[%key:component::my_pv::common::password_description%]"
        },
        "description": "The my-PV integration needs to re-authenticate with your my-PV device.",
        "title": "Authentication expired for {name}"
      },
      "setup_cloud": {
        "data": {
          "serial_number": "Serial number",
          "token": "[%key:component::my_pv::common::token%]"
        },
        "data_description": {
          "serial_number": "You can find the serial number on the device label.",
          "token": "[%key:component::my_pv::common::token_description%]"
        },
        "title": "my-PV Cloud Device"
      },
      "setup_local": {
        "data": {
          "host": "Host"
        },
        "data_description": {
          "host": "Host"
        },
        "title": "my-PV Local Device"
      },
      "user": {
        "description": "If your my-PV device is connected to your local network the **Local** method is the preferred method to connect.",
        "menu_options": {
          "setup_cloud": "Cloud",
          "setup_local": "Local"
        },
        "title": "Select connection method"
      }
    }
  },
  "device": {
    "my_pv": {
      "name": "{device_name}"
    }
  },
  "entity": {
    "binary_sensor": {
      "blockactive": {
        "name": "Block Status"
      }
    },
    "number": {
      "bsttemp": {
        "name": "Boost Target Temperature"
      },
      "maxpwr": {
        "name": "Maximum Power"
      },
      "ww1boost": {
        "name": "Boost Target Temperature"
      },
      "ww_boost_h": {
        "name": "Minimum Hysteresis"
      },
      "ww_targ_h": {
        "name": "Maximum Hysteresis"
      }
    },
    "select": {
      "bstmode": {
        "name": "Boost Mode",
        "state": {
          "0": "Off",
          "1": "On",
          "3": "Relais",
          "4": "SELV-Relais",
          "5": "AUX-Relais"
        }
      }
    },
    "sensor": {
      "cur_eth_mode": {
        "name": "Network Mode",
        "state": {
          "0": "LAN",
          "1": "WLAN",
          "2": "AP"
        }
      },
      "curr_l1": {
        "name": "Current phase L1"
      },
      "curr_l2": {
        "name": "Current phase L2"
      },
      "curr_l3": {
        "name": "Current phase L3"
      },
      "freq": {
        "name": "Mains Frequency"
      },
      "screen_mode_flag": {
        "name": "Device Status",
        "state": {
          "0": "Standby",
          "1": "Heat",
          "2": "Boost",
          "3": "Heating finished",
          "4": "No connection / Disabled",
          "5": "Failure",
          "6": "Block active"
        }
      },
      "soc": {
        "name": "Boiler State of Charge"
      },
      "temp1": {
        "name": "Temperature 1"
      },
      "temp2": {
        "name": "Temperature 2"
      },
      "temp3": {
        "name": "Temperature 3"
      },
      "temp4": {
        "name": "Temperature 4"
      },
      "uptime": {
        "name": "Uptime"
      },
      "volt_l1": {
        "name": "Voltage phase L1"
      },
      "volt_l2": {
        "name": "Voltage phase L2"
      },
      "volt_l3": {
        "name": "Voltage phase L3"
      },
      "wifi_signal": {
        "name": "Wi-Fi Signal Strength",
        "state": {
          "0": "Poor",
          "1": "Low",
          "2": "Average",
          "3": "Good",
          "4": "Strong"
        }
      },
      "wifi_signal_strength": {
        "name": "Wi-Fi Signal Strength"
      }
    },
    "switch": {
      "boostactive": {
        "name": "Boost Active"
      },
      "bstmode": {
        "name": "Boost Mode"
      },
      "bststrt": {
        "name": "Manual Boost"
      }
    }
  },
  "exceptions": {
    "config_type_not_supported": {
      "message": "Configuration type {config_type} is not supported"
    },
    "could_not_connect": {
      "message": "Could not connect to {uri}"
    },
    "device_unavailable": {
      "message": "Device on {uri} is unavailable"
    }
  }
}
