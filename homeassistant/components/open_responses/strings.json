      "invalid_auth": "[%key:common::config_flow::error::invalid_auth%]",
      "unknown": "[%key:common::config_flow::error::unknown%]"
    },
    "step": {
      "reauth_confirm": {
        "data": {
          "api_key": "[%key:common::config_flow::data::api_key%]",
          "base_url": "[%key:component::open_responses::config::step::user::data::base_url%]"
        },
        "data_description": {
          "api_key": "[%key:component::open_responses::config::step::user::data_description::api_key%]",
          "base_url": "[%key:component::open_responses::config::step::user::data_description::base_url%]"
        },
        "description": "Reauthentication required. Please enter your updated connection details."
      },
      "user": {
        "data": {
          "api_key": "[%key:common::config_flow::data::api_key%]",
          "base_url": "Base URL"
        },
        "data_description": {
          "api_key": "The API key for your OpenAI Responses API-compatible endpoint.",
          "base_url": "The full API base URL for an endpoint that implements the OpenAI Responses API, for example a proxy or self-hosted gateway. Compatibility issues with third-party endpoints should be reproduced against that endpoint before reporting them to Home Assistant."
        },
        "description": "Set up Open Responses by providing an API key and an OpenAI Responses API-compatible base URL. See the documentation for requirements and support boundaries: {docs_url}"
      }
    }
  },
