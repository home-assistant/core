{
  "config": {
    "abort": {
      "already_configured": "[%key:common::config_flow::abort::already_configured_service%]",
      "reauth_successful": "[%key:common::config_flow::abort::reauth_successful%]"
    },
    "error": {
      "unknown": "[%key:common::config_flow::error::unknown%]"
    },
    "step": {
      "reauth_confirm": {
        "data": {
          "api_key": "[%key:common::config_flow::data::api_key%]",
          "base_url": "[%key:component::open_responses::config::step::user::data::base_url%]"
        },
        "data_description": {
          "api_key": "[%key:component::open_responses::config::step::user::data_description::api_key%]",
          "base_url": "[%key:component::open_responses::config::step::user::data_description::base_url%]"
        },
        "description": "Reauthentication required. Please enter your updated connection details."
      },
      "user": {
        "data": {
          "api_key": "API key",
          "base_url": "Base URL"
        },
        "data_description": {
          "api_key": "The API key for your OpenAI Responses API-compatible endpoint.",
          "base_url": "The full API base URL for an endpoint that implements the OpenAI Responses API."
        },
        "description": "Set up Open Responses by providing an API key and an OpenAI Responses API-compatible base URL."
      }
    }
  },
  "config_subentries": {
    "ai_task_data": {
      "abort": {
        "entry_not_loaded": "[%key:component::open_responses::config_subentries::conversation::abort::entry_not_loaded%]",
        "reconfigure_successful": "[%key:common::config_flow::abort::reconfigure_successful%]"
      },
      "entry_type": "AI task",
      "initiate_flow": {
        "reconfigure": "Reconfigure AI task",
        "user": "Add AI task"
      },
      "step": {
        "init": {
          "data": {
            "max_output_tokens": "[%key:component::open_responses::config_subentries::conversation::step::init::data::max_output_tokens%]",
            "model": "[%key:common::generic::model%]",
            "name": "[%key:common::config_flow::data::name%]",
            "store_responses": "[%key:component::open_responses::config_subentries::conversation::step::init::data::store_responses%]"
          },
          "data_description": {
            "store_responses": "[%key:component::open_responses::config_subentries::conversation::step::init::data_description::store_responses%]"
          }
        }
      }
    },
    "conversation": {
      "abort": {
        "entry_not_loaded": "Cannot add things while the configuration is disabled.",
        "reconfigure_successful": "[%key:common::config_flow::abort::reconfigure_successful%]"
      },
      "entry_type": "Conversation agent",
      "initiate_flow": {
        "reconfigure": "Reconfigure conversation agent",
        "user": "Add conversation agent"
      },
      "step": {
        "init": {
          "data": {
            "llm_hass_api": "[%key:common::config_flow::data::llm_hass_api%]",
            "max_output_tokens": "Maximum output tokens",
            "model": "[%key:common::generic::model%]",
            "name": "[%key:common::config_flow::data::name%]",
            "prompt": "[%key:common::config_flow::data::prompt%]",
            "store_responses": "Store responses"
          },
          "data_description": {
            "prompt": "Instruct how the LLM should respond. This can be a template.",
            "store_responses": "If enabled, the compatible endpoint may store request and response data."
          }
        }
      }
    }
  },
  "exceptions": {
    "invalid_config_entry": {
      "message": "Invalid config entry provided. Got {config_entry}"
    }
  }
}
