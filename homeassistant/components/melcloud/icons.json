        }
      },
      "valve_2way_status": {
        "default": "mdi:valve-closed",
        "state": {
          "on": "mdi:valve-open"
        }
      },
      "valve_3way_status": {
        "default": "mdi:valve-closed",
        "state": {
          "on": "mdi:valve-open"
        }
      }
    },
    "sensor": {
      "energy_consumed": {
        "default": "mdi:factory"
      },
      "fan_frequency": {
        "default": "mdi:fan"
      }
    }
