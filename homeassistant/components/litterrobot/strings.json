        "config_entry_id": {
          "description": "The Litter-Robot config entry. Auto-detected if only one exists.",
          "name": "Config entry"
        },
        "event_id": {
          "description": "The event ID of the pet visit to reassign.",
          "name": "Event ID"
        },
        "from_pet_id": {
