        "for": {
          "name": "[%key:component::schedule::common::condition_for_name%]"
        }
      },
      "name": "Schedule is off"
    },
    "is_on": {
      "description": "Tests if one or more schedule blocks are currently active.",
      "fields": {
        "for": {
          "name": "[%key:component::schedule::common::condition_for_name%]"
        }
      },
      "name": "Schedule is on"
    }
  },
  "entity_component": {
    "_": {
      "name": "[%key:component::schedule::title%]",
      "state": {
