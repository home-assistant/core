{
  "config": {
    "abort": {
      "already_configured": "[%key:common::config_flow::abort::already_configured_device%]",
      "reauth_successful": "[%key:common::config_flow::abort::reauth_successful%]"
    },
    "error": {
      "cannot_connect": "[%key:common::config_flow::error::cannot_connect%]",
      "unknown": "[%key:common::config_flow::error::unknown%]"
    },
    "step": {
      "reauth_confirm": {
        "data": {
          "password": "[%key:component::ccm15::config::step::user::data::password%]"
        },
        "data_description": {
          "password": "[%key:component::ccm15::config::step::user::data_description::password%]"
        },
        "description": "Re-enter the password from your CCM15 controller's settings page."
      },
      "user": {
        "data": {
          "host": "[%key:common::config_flow::data::host%]",
          "password": "Device password",
          "port": "[%key:common::config_flow::data::port%]"
        },
        "data_description": {
          "password": "The password configured on the CCM15 controller's settings page (factory default 123456). Leave empty if your controller has no password."
        }
      }
    }
  }
}
