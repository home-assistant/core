  "issues": {
    "runtime_client_error": {
      "fix_flow": {
        "step": {
          "confirm": {
            "description": "The ECHONET Lite integration encountered an error: {error}. This may be caused by network issues or device disconnection.\n\nPress Submit to restart the ECHONET Lite integration and attempt recovery. If the problem persists, check your network configuration.",
            "title": "Restart ECHONET Lite integration"
          }
        }
      },
      "title": "ECHONET Lite runtime error"
    },
    "runtime_inactive": {
      "fix_flow": {
        "step": {
          "confirm": {
            "description": "No frames have been received from ECHONET Lite devices for more than {minutes} minutes. This may indicate that devices are offline or there is a network issue.\n\nPress Submit to restart the ECHONET Lite integration. Check that your ECHONET Lite devices are powered on and connected to the network.",
            "title": "Restart ECHONET Lite integration"
          }
        }
      },
      "title": "ECHONET Lite devices not responding"
    }
  },
  "options": {
    "step": {
      "init": {
        "data": {
          "enable_experimental": "Enable experimental device classes",
          "poll_interval": "Polling interval"
        },
        "data_description": {
          "enable_experimental": "When enabled, device classes that have not been verified with real hardware will also be registered. These may not work correctly.",
          "poll_interval": "How often to poll device properties (in seconds). Lower values provide faster updates but increase network traffic."
        }
      }
    }
  }
