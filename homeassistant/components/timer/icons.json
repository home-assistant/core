{
  "conditions": {
    "is_active": {
      "condition": "mdi:timer"
    },
    "is_idle": {
      "condition": "mdi:timer-off"
    },
    "is_paused": {
      "condition": "mdi:timer-pause"
    }
  },
  "services": {
    "cancel": {
      "service": "mdi:cancel"
    },
    "change": {
      "service": "mdi:pencil"
    },
    "finish": {
      "service": "mdi:check"
    },
    "pause": {
      "service": "mdi:pause"
    },
    "reload": {
      "service": "mdi:reload"
    },
    "start": {
      "service": "mdi:play"
    }
  }
}
