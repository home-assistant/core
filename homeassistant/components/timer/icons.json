{
  "services": {
    "cancel": {
      "service": "mdi:cancel"
    },
    "change": {
      "service": "mdi:pencil"
    },
    "finish": {
      "service": "mdi:check"
    },
    "pause": {
      "service": "mdi:pause"
    },
    "reload": {
      "service": "mdi:reload"
    },
    "start": {
      "service": "mdi:play"
    }
  },
  "triggers": {
    "cancelled": {
      "trigger": "mdi:timer-cancel-outline"
    },
    "finished": {
      "trigger": "mdi:timer-check-outline"
    },
    "paused": {
      "trigger": "mdi:timer-pause-outline"
    },
    "restarted": {
      "trigger": "mdi:timer-refresh-outline"
    },
    "started": {
      "trigger": "mdi:timer-play-outline"
    }
  }
}
