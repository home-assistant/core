{
  "entity": {
    "binary_sensor": {
      "smoke_sensor_state": {
        "default": "mdi:smoke",
        "state": {
          "on": "mdi:smoke-detector",
          "off": "mdi:smoke-detector-variant"
        }
      },
      "water_sensor_state": {
        "default": "mdi:water",
        "state": {
          "on": "mdi:water-check",
          "off": "mdi:water-off"
        }
      },
      "tamper_state": {
        "default": "mdi:alert",
        "state": {
          "on": "mdi:alert-circle",
          "off": "mdi:shield-check"
        }
      },
      "under_volt_error": {
        "default": "mdi:battery-alert-variant",
        "state": {
          "on": "mdi:battery-alert",
          "off": "mdi:battery-check"
        }
      },
      "freezing_point_alarm": {
        "default": "mdi:water-thermometer-outline",
        "state": {
          "on": "mdi:snowflake-alert",
          "off": "mdi:snowflake"
        }
      },
      "motion_status": {
        "default": "mdi:motion-sensor-off",
        "state": {
          "on": "mdi:motion-sensor",
          "off": "mdi:motion-sensor-off"
        }
      },
      "door_status": {
        "default": "mdi:door-closed",
        "state": {
          "on": "mdi:door-open",
          "off": "mdi:door-closed"
        }
      },
      "co_status": {
        "default": "mdi:molecule-co",
        "state": {
          "on": "mdi:molecule-co-warning",
          "off": "mdi:check-circle"
        }
      }
    },
    "sensor": {
      "current_temperature": {
        "default": "mdi:thermometer"
      },
      "battery_percentage": {
        "default": "mdi:battery",
        "state": {
          "0-10": "mdi:battery-alert-variant-outline",
          "11-20": "mdi:battery-10",
          "21-30": "mdi:battery-20",
          "31-40": "mdi:battery-30",
          "41-50": "mdi:battery-40",
          "51-60": "mdi:battery-50",
          "61-70": "mdi:battery-60",
          "71-80": "mdi:battery-70",
          "81-90": "mdi:battery-80",
          "91-100": "mdi:battery-charging"
        }
      },
      "deviceinfo_dbm": {
        "default": "mdi:signal"
      },
      "deviceinfo_dbm_level": {
        "default": "mdi:signal",
        "state": {
          "strong": "mdi:signal-strong",
          "medium": "mdi:signal-distance-variant",
          "weak": "mdi:signal-2g",
          "very_weak": "mdi:signal-off"
        }
      },
      "rssi_level": {
        "default": "mdi:signal",
        "state": {
          "strong": "mdi:signal-strong",
          "medium": "mdi:signal-distance-variant",
          "weak": "mdi:signal-2g",
          "very_weak": "mdi:signal-off"
        }
      },
      "deviceinfo_mac": {
        "default": "mdi:dharmachakra"
      },
      "deviceinfo_ip": {
        "default": "mdi:ip"
      },
      "device_mac": {
        "default": "mdi:dharmachakra"
      },
      "humidity": {
        "default": "mdi:water-percent"
      },
      "temperature": {
        "default": "mdi:thermometer"
      },
      "signal_strength": {
        "default": "mdi:signal"
      },
      "rssi": {
        "default": "mdi:signal"
      }
    },
    "switch": {
      "light_switch": {
        "default": "mdi:lightbulb-outline",
        "state": {
          "on": "mdi:lightbulb-on",
          "off": "mdi:lightbulb-off"
        }
      },
      "freezing_point_enable": {
        "default": "mdi:snowflake-alert",
        "state": {
          "on": "mdi:snowflake-check",
          "off": "mdi:snowflake-off"
        }
      },
      "buzzer_enable": {
        "default": "mdi:surround-sound",
        "state": {
          "on": "mdi:volume-high",
          "off": "mdi:volume-off"
        }
      }
    },
    "button": {
      "remote_locate": {
        "default": "mdi:radar"
      },
      "remote_check": {
        "default": "mdi:clipboard-check"
      },
      "mute": {
        "default": "mdi:volume-mute"
      },
      "reset": {
        "default": "mdi:reload"
      }
    },
    "select": {
      "alarm_sound_option": {
        "default": "mdi:volume-high"
      },
      "time_zone": {
        "default": "mdi:clock-time-nine-outline"
      }
    },
    "update": {
      "firmware_update": {
        "default": "mdi:package-up"
      }
    }
  },
  "services": {
    "read_device_properties": {
      "service": "mdi:file-document-outline"
    }
  }
}
