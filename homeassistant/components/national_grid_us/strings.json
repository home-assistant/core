{
  "config": {
    "abort": {
      "already_configured": "[%key:common::config_flow::abort::already_configured_account%]",
      "reauth_successful": "[%key:common::config_flow::abort::reauth_successful%]"
    },
    "error": {
      "cannot_connect": "[%key:common::config_flow::error::cannot_connect%]",
      "invalid_auth": "[%key:common::config_flow::error::invalid_auth%]",
      "no_accounts_selected": "Please select at least one account.",
      "unknown": "[%key:common::config_flow::error::unknown%]"
    },
    "step": {
      "reauth_confirm": {
        "data": {
          "password": "[%key:common::config_flow::data::password%]"
        },
        "data_description": {
          "password": "[%key:component::national_grid_us::config::step::user::data_description::password%]"
        },
        "description": "Please re-enter the password for {username}."
      },
      "select_accounts": {
        "data": {
          "selected_accounts": "Billing accounts"
        },
        "data_description": {
          "selected_accounts": "The billing accounts to monitor."
        },
        "description": "Select which billing accounts to monitor."
      },
      "user": {
        "data": {
          "password": "[%key:common::config_flow::data::password%]",
          "username": "[%key:common::config_flow::data::username%]"
        },
        "data_description": {
          "password": "The password for your National Grid account.",
          "username": "The username for your National Grid account."
        },
        "description": "Enter your National Grid account credentials."
      }
    }
  },
  "entity": {
    "sensor": {
      "energy_cost": {
        "name": "Last billing cost"
      },
      "energy_usage": {
        "name": "Last billing usage"
      }
    }
  }
}
