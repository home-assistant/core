{
  "domain": "bosch_shc_camera",
  "name": "Bosch Smart Home Camera",
  "codeowners": [
    "@mosandlt"
  ],
  "config_flow": true,
  "dependencies": [
    "application_credentials",
    "my",
    "http",
    "media_source"
