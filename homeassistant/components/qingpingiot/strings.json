{
  "config": {
    "abort": {
      "already_configured": "[%key:common::config_flow::abort::already_configured_device%]"
    },
    "error": {
      "invalid_mac": "Invalid MAC address format. Use 12 hex characters (e.g. AABBCCDDEEFF)."
    },
    "step": {
      "confirm": {
        "data": {
          "model": "Model",
          "name": "[%key:common::config_flow::data::name%]"
        },
        "description": "MAC: {mac}",
        "title": "Confirm Device"
