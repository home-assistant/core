        },
        "description": "Enter device MAC address and select model.",
        "title": "Add Device Manually"
      },
      "reconfigure": {
        "data": {
          "model": "Model"
        },
        "data_description": {
          "model": "Select the device model to update."
        },
        "description": "Update settings for {device_name}.",
        "title": "Reconfigure Device"
      },
