{
  "conditions": {
    "is_event_active": {
      "condition": "mdi:calendar-check"
    }
  },
  "entity_component": {
    "_": {
      "default": "mdi:calendar",
      "state": {
        "off": "mdi:calendar-blank",
        "on": "mdi:calendar-check"
      }
    }
  },
  "services": {
    "create_event": {
      "service": "mdi:calendar-plus"
    },
    "get_events": {
      "service": "mdi:calendar-month"
    }
  },
  "triggers": {
    "event_ended": {
      "trigger": "mdi:calendar-end"
    },
    "event_started": {
      "trigger": "mdi:calendar-start"
    }
  }
}
