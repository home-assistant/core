        },
        "title": "Lyngdorf device connection"
      }
    }
  },
  "device": {
    "zone_b": {
      "name": "{device_name} Zone B"
    }
  },
  "entity": {
    "media_player": {
      "main_zone": {
        "name": "Main zone"
      },
      "zone_b": {
        "name": "Zone B"
      }
    }
  },
  "exceptions": {
    "setup_connection_error": {
      "message": "Failed to connect to {host}"
    },
    "setup_timeout": {
      "message": "Timeout connecting to {host}"
    },
    "unsupported_model": {
      "message": "Unsupported Lyngdorf model: {model}"
    }
