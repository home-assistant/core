{
  "config": {
    "step": {
      "user": {
        "description": "Enter your Sharp Members EU account credentials.",
        "data": {
          "email": "[%key:common::config_flow::data::email%]",
          "password": "[%key:common::config_flow::data::password%]"
        },
        "data_description": {
          "email": "The email address for your Sharp Members EU account.",
          "password": "The password for your Sharp Members EU account."
        }
      },
      "reauth_confirm": {
        "description": "Your session has expired. Please enter your credentials again.",
        "data": {
          "email": "[%key:common::config_flow::data::email%]",
          "password": "[%key:common::config_flow::data::password%]"
        },
        "data_description": {
          "email": "[%key:component::sharp_cocoro_air::config::step::user::data_description::email%]",
          "password": "[%key:component::sharp_cocoro_air::config::step::user::data_description::password%]"
        }
      }
    },
    "error": {
      "cannot_connect": "[%key:common::config_flow::error::cannot_connect%]",
      "invalid_auth": "[%key:common::config_flow::error::invalid_auth%]",
      "unknown": "[%key:common::config_flow::error::unknown%]"
    },
    "abort": {
      "already_configured": "[%key:common::config_flow::abort::already_configured_account%]",
      "reauth_successful": "[%key:common::config_flow::abort::reauth_successful%]",
      "reconfigure_successful": "[%key:common::config_flow::abort::reconfigure_successful%]",
      "unique_id_mismatch": "The email address does not match the previously configured account."
    }
  },
  "exceptions": {
    "auth_failed": {
      "message": "Authentication with Sharp cloud failed"
    },
    "relogin_failed": {
      "message": "Re-login to Sharp cloud failed"
    },
    "cannot_connect": {
      "message": "Cannot connect to Sharp cloud: {error}"
    },
    "command_failed": {
      "message": "Command failed: {error}"
    }
  },
  "entity": {
    "fan": {
      "air_purifier": {
        "name": "Air purifier",
        "state_attributes": {
          "preset_mode": {
            "state": {
              "auto": "Auto",
              "night": "Night",
              "pollen": "Pollen",
              "silent": "Silent",
              "medium": "Medium",
              "high": "High",
              "ai_auto": "AI auto",
              "realize": "Turbo clean"
            }
          }
        }
      }
    }
  }
}
