{
  "config": {
    "abort": {
      "already_configured": "[%key:common::config_flow::abort::already_configured_device%]",
      "reauth_successful": "[%key:common::config_flow::abort::reauth_successful%]"
    },
    "error": {
      "cannot_connect": "[%key:common::config_flow::error::cannot_connect%]",
      "invalid_auth": "[%key:common::config_flow::error::invalid_auth%]",
      "unknown": "[%key:common::config_flow::error::unknown%]"
    },
    "step": {
      "reauth_confirm": {
        "data": {
          "password": "[%key:common::config_flow::data::password%]"
        },
        "description": "Please enter the password for the Powerwall.",
        "title": "Reauthenticate the Powerwall"
      },
      "user": {
        "data": {
          "ip_address": "[%key:common::config_flow::data::ip%]",
          "password": "[%key:common::config_flow::data::password%]"
        },
        "description": "The password is typically the last 5 characters of the serial number found on the Powerwall or in the Tesla app.",
        "title": "Connect to the Powerwall"
      }
    }
  },
  "entity": {
    "binary_sensor": {
      "battery_charging": {
        "name": "Battery charging"
      },
      "grid_connected": {
        "name": "Grid connected"
      },
      "grid_services_active": {
        "name": "Grid services active"
      }
    },
    "sensor": {
      "battery_energy_exported": {
        "name": "Battery energy exported"
      },
      "battery_energy_imported": {
        "name": "Battery energy imported"
      },
      "battery_frequency": {
        "name": "Battery frequency"
      },
      "battery_level": {
        "name": "Battery level"
      },
      "battery_power": {
        "name": "Battery power"
      },
      "grid_current": {
        "name": "Grid current"
      },
      "grid_energy_exported": {
        "name": "Grid energy exported"
      },
      "grid_energy_imported": {
        "name": "Grid energy imported"
      },
      "grid_frequency": {
        "name": "Grid frequency"
      },
      "grid_power": {
        "name": "Grid power"
      },
      "grid_status": {
        "name": "Grid status"
      },
      "grid_voltage": {
        "name": "Grid voltage"
      },
      "load_energy": {
        "name": "Load energy"
      },
      "load_power": {
        "name": "Load power"
      },
      "solar_energy": {
        "name": "Solar energy"
      },
      "solar_power": {
        "name": "Solar power"
      }
    }
  }
}
