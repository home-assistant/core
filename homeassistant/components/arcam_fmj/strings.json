{
  "config": {
    "abort": {
      "already_configured": "[%key:common::config_flow::abort::already_configured_device%]",
      "already_in_progress": "[%key:common::config_flow::abort::already_in_progress%]",
      "cannot_connect": "[%key:common::config_flow::error::cannot_connect%]"
    },
    "flow_title": "{host}",
    "step": {
      "confirm": {
        "description": "Do you want to add Arcam FMJ on `{host}` to Home Assistant?"
      },
      "user": {
        "data": {
          "host": "[%key:common::config_flow::data::host%]",
          "port": "[%key:common::config_flow::data::port%]"
        },
        "description": "Please enter the host name or IP address of device."
      }
    }
  },
  "device_automation": {
    "trigger_type": {
      "turn_on": "{entity_name} was requested to turn on"
    }
  },
  "entity": {
    "sensor": {
      "incoming_audio_config": {
        "name": "Zone {zone} incoming audio configuration"
      },
      "incoming_audio_format": {
        "name": "Zone {zone} incoming audio format"
      },
      "incoming_audio_sample_rate": {
        "name": "Zone {zone} incoming audio sample rate"
      },
      "incoming_video_aspect_ratio": {
        "name": "Zone {zone} incoming video aspect ratio"
      },
      "incoming_video_colorspace": {
        "name": "Zone {zone} incoming video colorspace"
      },
      "incoming_video_horizontal_resolution": {
        "name": "Zone {zone} incoming video horizontal resolution"
      },
      "incoming_video_refresh_rate": {
        "name": "Zone {zone} incoming video refresh rate"
      },
      "incoming_video_vertical_resolution": {
        "name": "Zone {zone} incoming video vertical resolution"
      }
    }
  }
}
