          "host": "The IP address or hostname of the AirTouch 3 controller."
        }
      },
      "user": {
        "data": {
          "host": "Host"
        },
        "data_description": {
          "host": "The IP address or hostname of the AirTouch 3 controller."
        },
        "description": "If you leave the host empty, discovery will be used to find controllers."
      }
    }
  },
  "entity": {
    "climate": {
      "air_conditioner": {
        "name": "Air conditioner"
      },
      "zone": {
        "name": "Zone"
      }
